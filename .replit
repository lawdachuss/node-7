modules = ["go-1.21", "web", "python-3.12", "bash", "nodejs-20", "postgresql-16"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["javascript_database:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["gitFull", "playwright-driver"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm ci && npm run build:css && python3 byparr_lite.py > /tmp/byparr.log 2>&1 & go run . --port 5000"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8191
externalPort = 3000

[deployment]
deploymentTarget = "vm"
run = ["./chaturbate-dvr", "--port", "5000"]
build = ["bash", "-c", "npm ci && npm run build:css && go build -o chaturbate-dvr ."]

[userenv]

[userenv.shared]
